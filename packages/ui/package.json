{
  "name": "@marcgm/sharkui",
  "version": "0.1.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "A React design system built on shadcn-ui (Base UI + Tailwind CSS v4)",
  "license": "MIT",
  "author": "Marc González Moratona",
  "type": "module",
  "keywords": [
    "react",
    "design-system",
    "ui",
    "components",
    "shadcn",
    "tailwindcss",
    "base-ui"
  ],
  "homepage": "https://github.com/MarcGonzalezMoratona/sharkui#readme",
  "bugs": "https://github.com/MarcGonzalezMoratona/sharkui/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarcGonzalezMoratona/sharkui.git",
    "directory": "packages/ui"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:css",
    "build:js": "tsup",
    "build:css": "tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.5.3",
    "@tailwindcss/cli": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.3",
    "tailwindcss": "^4.3.3",
    "tsup": "^8.5.1",
    "tw-animate-css": "^1.4.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  }
}
