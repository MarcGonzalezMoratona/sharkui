{
  "name": "@marcgm/sharkui",
  "version": "0.16.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "A React design system built on shadcn-ui (Base UI + Tailwind CSS v4)",
  "license": "MIT",
  "author": "Marc González Moratona",
  "type": "module",
  "keywords": [
    "react",
    "design-system",
    "ui",
    "components",
    "shadcn",
    "tailwindcss",
    "base-ui"
  ],
  "homepage": "https://github.com/MarcGonzalezMoratona/sharkui#readme",
  "bugs": "https://github.com/MarcGonzalezMoratona/sharkui/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarcGonzalezMoratona/sharkui.git",
    "directory": "packages/ui"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:types && pnpm run build:css",
    "build:js": "rollup -c",
    "build:types": "tsc -p tsconfig.build.json",
    "build:css": "tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "dev": "rollup -c --watch",
    "gen:component": "node scripts/generate-component.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@storybook/react-vite": "^10.5.3",
    "@tailwindcss/cli": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-istanbul": "^4.1.10",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rollup": "^4.62.2",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-preserve-directives": "^0.4.0",
    "storybook": "^10.5.3",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  }
}
