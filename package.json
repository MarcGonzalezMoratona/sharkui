{
  "name": "sharkui-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter docs storybook",
    "build": "pnpm -r build",
    "build-storybook": "pnpm --filter docs build-storybook",
    "lint": "oxlint",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "pnpm --filter @marcgm/sharkui test",
    "test:coverage": "vitest run --coverage",
    "test:stories": "pnpm --filter docs test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm --filter @marcgm/sharkui build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^24.13.2",
    "@vitest/coverage-istanbul": "^4.1.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.6",
    "typescript": "~6.0.2",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.34.5"
}
